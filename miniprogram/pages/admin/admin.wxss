/* pages/admin/admin.wxss */

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: #F0F0F0;
  border-radius: 16rpx;
  padding: 4rpx;
  margin-bottom: 24rpx;
}

.filter-tag {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #888;
  transition: all 0.2s;
}

.filter-tag-active {
  background: #fff;
  color: #FF8C42;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 标签切换 */
.admin-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.admin-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab-active {
  color: #FF8C42;
  font-weight: 600;
  background: #FFF3E0;
}

.tab-count {
  font-size: 22rpx;
  color: #999;
}

.tab-badge {
  background: #ff4444;
  color: #fff !important;
  border-radius: 20rpx;
  padding: 2rpx 12rpx;
  font-size: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 操作栏 */
.admin-action-bar {
  margin-bottom: 20rpx;
}

.btn-add {
  background: linear-gradient(135deg, #FF8C42, #FF6B35);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  padding: 16rpx 0;
}

.btn-add::after {
  border: none;
}

/* 列表项 */
.admin-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  gap: 20rpx;
}

.admin-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.admin-item-info {
  flex: 1;
  min-width: 0;
}

.admin-item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.admin-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.admin-item-meta {
  display: block;
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 4rpx;
}

/* 操作按钮 */
.admin-item-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  text-align: center;
}

.action-edit {
  background: #E3F2FD;
  color: #1565C0;
}

.action-delete {
  background: #FFEBEE;
  color: #C62828;
}

.action-approve {
  background: #E8F5E9;
  color: #2E7D32;
}

.action-reject {
  background: #FFEBEE;
  color: #C62828;
}

/* 领养申请状态 */
.tag-adoption-pending {
  background: #FFF3E0;
  color: #E65100;
}

.tag-adoption-approved {
  background: #E8F5E9;
  color: #2E7D32;
}

.tag-adoption-rejected {
  background: #FFEBEE;
  color: #C62828;
}

/* 鉴权失败 */
.auth-card {
  padding: 60rpx 40rpx;
  text-align: center;
  margin-top: 100rpx;
}

.auth-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.auth-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.auth-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.auth-openid {
  display: block;
  font-size: 24rpx;
  color: #FF8C42;
  word-break: break-all;
  padding: 16rpx;
  background: #FFF3E0;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.auth-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
