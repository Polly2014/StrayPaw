/* pages/agreement/agreement.wxss */

.agreement-page {
  padding-bottom: 60rpx;
}

.agreement-page .section-card {
  padding: 36rpx;
}

.agreement-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 8rpx;
}

.agreement-date {
  display: block;
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 40rpx;
}

.agreement-page .section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-top: 32rpx;
  margin-bottom: 12rpx;
}

.agreement-page .section-content {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 12rpx;
}

.agreement-page .section-content.bold {
  font-weight: 600;
  color: #444;
}
