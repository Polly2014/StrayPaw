<!--pages/adopt/adopt.wxml - 领养申请表-->
<view class="container">
  <view class="card form-card">
    <text class="form-title">领养申请 - {{animalName}}</text>
    <text class="form-subtitle">请认真填写以下信息，我们会尽快联系您</text>

    <!-- 姓名 -->
    <view class="form-group">
      <text class="form-label">姓名 <text class="required">*</text></text>
      <input
        class="form-input"
        placeholder="请输入您的真实姓名"
        value="{{form.name}}"
        bindinput="onInput"
        data-field="name"
      />
    </view>

    <!-- 手机号 -->
    <view class="form-group">
      <text class="form-label">手机号 <text class="required">*</text></text>
      <input
        class="form-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{form.phone}}"
        bindinput="onInput"
        data-field="phone"
      />
    </view>

    <!-- 微信号 -->
    <view class="form-group">
      <text class="form-label">微信号</text>
      <input
        class="form-input"
        placeholder="方便我们联系您"
        value="{{form.wechat}}"
        bindinput="onInput"
        data-field="wechat"
      />
    </view>

    <!-- 年龄 -->
    <view class="form-group">
      <text class="form-label">年龄 <text class="required">*</text></text>
      <input
        class="form-input"
        type="number"
        placeholder="需年满18周岁"
        value="{{form.age}}"
        bindinput="onInput"
        data-field="age"
      />
    </view>

    <!-- 居住情况 -->
    <view class="form-group">
      <text class="form-label">居住情况 <text class="required">*</text></text>
      <picker
        mode="selector"
        range="{{housingOptions}}"
        value="{{form.housingIndex}}"
        bindchange="onHousingChange"
      >
        <view class="form-picker {{form.housing ? '' : 'placeholder'}}">
          {{form.housing || '请选择居住情况'}}
        </view>
      </picker>
    </view>

    <!-- 是否养过宠物 -->
    <view class="form-group">
      <text class="form-label">是否养过宠物 <text class="required">*</text></text>
      <view class="radio-group">
        <view
          class="radio-item {{form.hasPetExp === true ? 'radio-active' : ''}}"
          bindtap="onPetExp"
          data-value="true"
        >是</view>
        <view
          class="radio-item {{form.hasPetExp === false ? 'radio-active' : ''}}"
          bindtap="onPetExp"
          data-value="false"
        >否</view>
      </view>
    </view>

    <!-- 家人是否同意 -->
    <view class="form-group">
      <text class="form-label">家人是否同意 <text class="required">*</text></text>
      <view class="radio-group">
        <view
          class="radio-item {{form.familyAgree === true ? 'radio-active' : ''}}"
          bindtap="onFamilyAgree"
          data-value="true"
        >同意</view>
        <view
          class="radio-item {{form.familyAgree === false ? 'radio-active' : ''}}"
          bindtap="onFamilyAgree"
          data-value="false"
        >未确认</view>
      </view>
    </view>

    <!-- 领养理由 -->
    <view class="form-group">
      <text class="form-label">为什么想领养 Ta？ <text class="required">*</text></text>
      <textarea
        class="form-textarea"
        placeholder="请简单说说您的领养理由，以及能为 Ta 提供怎样的生活..."
        value="{{form.reason}}"
        bindinput="onInput"
        data-field="reason"
        maxlength="500"
      />
      <text class="char-count">{{form.reason.length || 0}}/500</text>
    </view>

    <!-- 协议勾选 -->
    <view class="agreement-check">
      <view class="checkbox-wrapper" bindtap="toggleAgree">
        <view class="checkbox {{agreed ? 'checked' : ''}}">
          <text wx:if="{{agreed}}">✓</text>
        </view>
      </view>
      <text class="agreement-text">我已阅读并同意</text>
      <text class="agreement-link" bindtap="goAgreement">《用户服务协议》</text>
      <text class="agreement-text">和</text>
      <text class="agreement-link" bindtap="goPrivacy">《隐私保护指引》</text>
    </view>

    <!-- 提交按钮 -->
    <button class="btn-primary btn-submit" bindtap="onSubmit" loading="{{submitting}}">
      提交申请
    </button>
  </view>
</view>
