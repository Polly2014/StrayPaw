/* pages/adopt/adopt.wxss */

.form-card {
  padding: 32rpx;
}

.form-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.form-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.required {
  color: #FF4444;
}

.form-input {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.form-picker {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}

.form-picker.placeholder {
  color: #999;
}

.form-textarea {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
  height: 240rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #ccc;
  margin-top: 8rpx;
}

/* 单选组 */
.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background: #F8F8F8;
  font-size: 28rpx;
  color: #666;
}

.radio-active {
  background: #FFF3E0;
  color: #FF8C42;
  font-weight: 500;
  border: 2rpx solid #FF8C42;
}

/* 协议勾选 */
.agreement-check {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 32rpx;
  padding: 0 4rpx;
}

.checkbox-wrapper {
  margin-right: 12rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ccc;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.checkbox.checked {
  background: #FF8C42;
  border-color: #FF8C42;
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
}

.agreement-link {
  font-size: 24rpx;
  color: #FF8C42;
}

/* 提交按钮 */
.btn-submit {
  margin-top: 40rpx;
  width: 100%;
}
